# Path to local ChromaDB persistence directory
CHROMA_PATH=./data/chroma

# Collection name within ChromaDB (safe to rename per project)
CHROMA_COLLECTION=alcove_docs

# Directory containing source documents (txt, pdf, epub)
RAW_DIR=./data/raw

# Output file for chunked content
CHUNKS_FILE=./data/processed/chunks.jsonl

# Characters per chunk / overlap between chunks
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# API server bind address and port (used by `alcove serve`)
# Use 0.0.0.0 to expose on your network (Docker requires this)
API_HOST=127.0.0.1
API_PORT=8000

# ChromaDB telemetry — disabled by default (local-first product)
ANONYMIZED_TELEMETRY=False

# Embedder: hash (default, deterministic) or sentence-transformers (semantic)
EMBEDDER=hash

# Vector backend: chromadb (default) or zvec
VECTOR_BACKEND=chromadb

# Path to zvec persistence directory (only used when VECTOR_BACKEND=zvec)
ZVEC_PATH=./data/zvec
